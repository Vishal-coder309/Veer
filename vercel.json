{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/build",
  "functions": {
    "api/index.js": {
      "includeFiles": "server/**,node_modules/.prisma/**,node_modules/@prisma/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-analytics",
      "schedule": "30 17 * * *"
    },
    {
      "path": "/api/cron/daily-motivation",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/daily-reminders",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/inactivity-check",
      "schedule": "0 15 * * 0"
    },
    {
      "path": "/api/cron/inactivity-check",
      "schedule": "0 15 * * 1"
    }
  ]
}
