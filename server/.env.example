# Copy this file to .env and fill in your values.
# On Vercel, set these in: Project Settings → Environment Variables

# MongoDB Atlas connection string — used by Prisma (required for Vercel)
# Get it from: https://cloud.mongodb.com → your cluster → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/veer?retryWrites=true&w=majority
DATABASE_URL=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/veer?retryWrites=true&w=majority

# A long random secret for JWT signing (generate one at: https://generate-secret.vercel.app/32)
JWT_SECRET=replace_this_with_a_long_random_string_at_least_32_chars

# Port for local development only (Vercel ignores this)
PORT=5000

NODE_ENV=production

# Gmail SMTP — use a Gmail App Password (not your real password)
# Generate at: Google Account → Security → 2-Step Verification → App Passwords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=xxxx xxxx xxxx xxxx
MAIL_FROM="VEER Study Tracker <your_email@gmail.com>"

# Your deployed frontend URL (used in email links)
CLIENT_URL=https://your-app.vercel.app

# Vercel Cron secret — set this in Vercel env vars too
# Any random string; Vercel sends it as Authorization: Bearer <secret>
CRON_SECRET=replace_with_random_secret
